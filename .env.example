# Global
AWS_REGION=us-east-1
AWS_ENDPOINT_OVERRIDE=
SCHEMA_PATH=shared/schemas/payment/v1.json

# Data plane
KINESIS_STREAM_NAME=payment-events-stream
DATA_LAKE_BUCKET=data-platform-lake
RETRY_QUEUE_URL=
DLQ_QUEUE_URL=
MAX_ATTEMPTS=5

# Postgres
DB_URL=jdbc:postgresql://localhost:5432/dataplatform
DB_USERNAME=dataplatform
DB_PASSWORD=dataplatform

# Control plane security (Cognito)
SECURITY_ENABLED=false
COGNITO_ISSUER_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend
VITE_CONTROL_PLANE_URL=http://localhost:8081
VITE_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your-client-id
VITE_COGNITO_REDIRECT_URI=http://localhost:5173
VITE_COGNITO_LOGOUT_URI=http://localhost:5173
VITE_COGNITO_SCOPE=openid profile email
